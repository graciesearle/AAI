DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,ai-service

# Model routing defaults
MODEL_ROOT=/app/models
DEFAULT_MODEL_NAME=produce-quality
DEFAULT_MODEL_VERSION=1.0.0
DEFAULT_TASK_PROFILE=task2_quality

# Task 2 notebook / Colab / local training settings
TASK2_RUN_ENV=auto # Options: "auto" (default, auto-detects colab vs local), "colab", "local"
TASK2_REPO_URL=https://github.com/graciesearle/AAI.git
TASK2_REPO_DIR= # Optional: specify a local path to the cloned repo if not using the URL (e.g. for local development). If set, this will be used instead of cloning from the URL.
TASK2_KAGGLE_DATASET=muhammad0subhan/fruit-and-vegetable-disease-healthy-vs-rotten
TASK2_DATASET_DIR=FruitAndVegetableDataset
TASK2_EXPORT_DIR= 
TASK2_INSTALL_DEPS=1 # Set to 1 to allow the notebook to install dependencies (like PyTorch) if not already present. Set to 0 to skip installation (useful if you have a custom environment or want to manage deps yourself).
TASK2_ALLOW_KAGGLE_DOWNLOAD=1 # Set to 1 to allow the notebook to download the dataset directly from Kaggle using the Kaggle API. Requires KAGGLE_USERNAME and KAGGLE_KEY to be set. Set to 0 to skip downloading (useful if you have already downloaded and mounted the dataset).
TASK2_USE_PRETRAINED=1 # Set to 1 to use a pretrained model for quick testing and iteration. Set to 0 to train from scratch (will take longer and require more resources).
TASK2_EPOCHS=12 # Number of training epochs for Task 2 model training. Adjust as needed based on your dataset and compute resources.
TASK2_BATCH_SIZE=32 # Batch size for Task 2 model training. Adjust based on your GPU memory and dataset size.
TASK2_LEARNING_RATE=0.001 # Learning rate for Task 2 model training. Adjust based on your dataset and model architecture.
TASK2_QUALITY_LOSS_WEIGHT=0.4 # Weight applied to quality-head loss in the multitask raw classifier script.
TASK2_IMAGE_SIZE=224 # Input image size used by task2_raw_files/train_fresh_rotten_classifier.py
TASK2_PATIENCE=5 # Early-stopping patience for training.
TASK2_NUM_WORKERS=2 # Data loader workers for training.
TASK2_SEED=42 # Random seed for reproducible runs.
TASK2_SAVE_MODEL_PATH=task2_raw_files/fresh_rotten_resnet501.pth # Output checkpoint path for raw classifier script.
TASK2_SAVE_PLOT_PATH=task2_raw_files/learning_curves.png # Output plot path for raw classifier script.
TASK2_PREDICT_IMAGE= # Optional: image path for single-image inference after load/train.
TASK2_FORCE_TRAIN=0 # 0 = load existing checkpoint when available, 1 = retrain from scratch.
TASK2_FULL_EVAL_ON_LOAD=0 # 0 = skip full dataset evaluation when loading checkpoint, 1 = run evaluation.
TASK2_KAGGLE_DOWNLOAD_DIR=. # Directory where Kaggle zip files are downloaded when enabled.

# Kaggle credentials for automatic dataset download 
KAGGLE_USERNAME=
KAGGLE_KEY=